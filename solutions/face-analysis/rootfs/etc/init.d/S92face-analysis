#!/bin/sh

### BEGIN INIT INFO
# Provides:          face-analysis
# Required-Start:    $network $local_fs
# Required-Stop:     $network $local_fs
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Short-Description: Face Detection & Analysis (age/gender/emotion)
### END INIT INFO

NAME=face-analysis
DAEMON=/usr/local/bin/face-analysis
PIDFILE=/var/run/$NAME.pid
LOGFILE=/var/log/$NAME.log

# Library paths required for CVI SDK
export LD_LIBRARY_PATH=/mnt/system/lib:/mnt/system/usr/lib:/mnt/system/usr/lib/3rd:/mnt/system/lib/3rd:/lib:/usr/lib

# Load config if exists
[ -f /etc/face-analysis.conf ] && . /etc/face-analysis.conf

# Build options from config
DAEMON_OPTS=""
[ -n "$FACE_MODEL" ] && DAEMON_OPTS="$DAEMON_OPTS -f $FACE_MODEL"
[ -n "$GENDERAGE_MODEL" ] && DAEMON_OPTS="$DAEMON_OPTS -g $GENDERAGE_MODEL"
[ -n "$EMOTION_MODEL" ] && DAEMON_OPTS="$DAEMON_OPTS -e $EMOTION_MODEL"
[ -n "$FACE_THRESHOLD" ] && DAEMON_OPTS="$DAEMON_OPTS -t $FACE_THRESHOLD"
[ -n "$MQTT_HOST" ] && DAEMON_OPTS="$DAEMON_OPTS -m $MQTT_HOST"
[ -n "$MQTT_PORT" ] && DAEMON_OPTS="$DAEMON_OPTS -p $MQTT_PORT"
[ "$RTSP_ENABLED" = "0" ] && DAEMON_OPTS="$DAEMON_OPTS --no-rtsp"
[ "$BLUR_ENABLED" = "0" ] && DAEMON_OPTS="$DAEMON_OPTS --no-blur"
[ -n "$MAX_REGIONS" ] && DAEMON_OPTS="$DAEMON_OPTS --max-regions $MAX_REGIONS"
[ "$VERBOSE" = "1" ] && DAEMON_OPTS="$DAEMON_OPTS -v"

# Stop conflicting services that use the camera
stop_conflicting_services() {
    echo "Stopping conflicting services..."
    for prefix in S K; do
        [ -x /etc/init.d/${prefix}91sscma-node ] && /etc/init.d/${prefix}91sscma-node stop 2>/dev/null || true
        [ -x /etc/init.d/${prefix}03node-red ] && /etc/init.d/${prefix}03node-red stop 2>/dev/null || true
        [ -x /etc/init.d/${prefix}93sscma-supervisor ] && /etc/init.d/${prefix}93sscma-supervisor stop 2>/dev/null || true
    done
    # Stop other camera-using solutions
    for svc in ppocr-reader detection-blur retail-vision yolo8-detector yolo11-detector yolo11s-detector yolo26-detector; do
        for script in /etc/init.d/[SK]*${svc}; do
            [ -x "$script" ] && "$script" stop 2>/dev/null || true
        done
    done
    sleep 2
}

start() {
    echo "Starting $NAME..."
    if [ -f $PIDFILE ]; then
        PID=$(cat $PIDFILE 2>/dev/null)
        if [ -n "$PID" ] && [ -d "/proc/$PID" ]; then
            echo "$NAME is already running (PID: $PID)"
            return 1
        fi
        rm -f $PIDFILE
    fi

    stop_conflicting_services

    start-stop-daemon -S -b -m -p $PIDFILE -a /bin/sh -- -c "exec $DAEMON $DAEMON_OPTS >> $LOGFILE 2>&1"
    echo "OK"
}

stop() {
    echo "Stopping $NAME..."
    if [ -f $PIDFILE ]; then
        start-stop-daemon -K -p $PIDFILE -s TERM
        rm -f $PIDFILE
        echo "OK"
    else
        echo "$NAME is not running"
    fi
}

restart() {
    stop
    sleep 2
    start
}

status() {
    if [ -f $PIDFILE ]; then
        PID=$(cat $PIDFILE 2>/dev/null)
        if [ -n "$PID" ] && [ -d "/proc/$PID" ]; then
            echo "$NAME is running (PID: $PID)"
            return 0
        fi
    fi
    PID=$(ps aux 2>/dev/null | grep "$DAEMON" | grep -v grep | awk '{print $1}' | head -1)
    if [ -n "$PID" ]; then
        echo "$NAME is running (PID: $PID)"
        return 0
    fi
    echo "$NAME is not running"
    return 1
}

case "$1" in
    start) start ;;
    stop) stop ;;
    restart) restart ;;
    status) status ;;
    *) echo "Usage: $0 {start|stop|restart|status}"; exit 1 ;;
esac

exit 0
